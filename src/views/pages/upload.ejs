<div class="upload-card">
    <h1>Novo episódio</h1>
    <p class="subtitle">Preencha os dados e envie seu áudio.</p>

    <form action="/upload" method="POST" enctype="multipart/form-data">

        <div class="form-group">
            <label for="title">Título</label>
            <input
                type="text"
                id="title"
                name="title"
                placeholder="Nome do episódio"
                required>
        </div>

        <div class="form-group">
            <label for="description">
                Descrição
                <span style="color: var(--text-muted); font-weight: 400;">
                    (opcional)
                </span>
            </label>

            <textarea
                id="description"
                name="description"
                placeholder="Sobre o que é este episódio?"></textarea>
        </div>

        <div class="form-group">
            <label for="category">
                Categoria
                <span style="color: var(--text-muted); font-weight: 400;">
                    (opcional)
                </span>
            </label>

            <select id="category" name="category">
                <option value="">Selecionar...</option>
                <option>Tecnologia</option>
                <option>Negócios</option>
                <option>Educação</option>
                <option>Entretenimento</option>
                <option>Saúde</option>
                <option>Outros</option>
            </select>
        </div>

        <!-- CAPA -->

        <div class="form-group">
            <label>Capa do episódio</label>

            <label class="file-input-label">
                <input
                    type="file"
                    name="cover"
                    id="cover-input"
                    accept="image/*">

                <span id="cover-name">
                    🖼️ Clique para selecionar uma capa
                </span>
            </label>

            <div class="cover-preview-wrapper">
                <img
                    id="cover-preview"
                    class="cover-preview"
                    style="display:none;"
                    alt="Prévia da capa">
            </div>
        </div>

        <!-- ÁUDIO -->

        <div class="form-group">
            <label>Arquivo de áudio</label>

            <label class="file-input-label">
                <input
                    type="file"
                    name="audio"
                    accept="audio/*"
                    required
                    id="audio-input">

                <span id="file-name">
                    🎵 Clique para selecionar o arquivo
                </span>
            </label>
        </div>

        <button type="submit" class="form-submit">
            Publicar episódio
        </button>

    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

    // ÁUDIO

    const audioInput = document.getElementById('audio-input');
    const fileName = document.getElementById('file-name');

    if (audioInput) {

        audioInput.addEventListener('change', function () {

            if (this.files.length > 0) {

                fileName.textContent =
                    '🎵 ' + this.files[0].name;

            }

        });

    }

    // CAPA

    const coverInput =
        document.getElementById('cover-input');

    const coverName =
        document.getElementById('cover-name');

    const preview =
        document.getElementById('cover-preview');

    if (coverInput) {

        coverInput.addEventListener('change', function () {

            if (this.files.length > 0) {

                const file = this.files[0];

                coverName.textContent =
                    '🖼️ ' + file.name;

                preview.src =
                    URL.createObjectURL(file);

                preview.style.display =
                    'block';
            }

        });

    }

});
</script>