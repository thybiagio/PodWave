<div class="upload-card">
    <h1>Novo episódio</h1>
    <p class="subtitle">Preencha os dados e envie seu áudio.</p>

<script>
document.querySelector('form').addEventListener('submit', () => {
    const input = document.getElementById('audio-input');

    console.log('FILES:', input.files);
    console.log('QTD:', input.files.length);

    if (input.files.length > 0) {
        console.log('NOME:', input.files[0].name);
        console.log('TIPO:', input.files[0].type);
        console.log('TAMANHO:', input.files[0].size);
    }
});
</script>
    
    <form action="/upload" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Título</label>
            <input type="text" id="title" name="title" placeholder="Nome do episódio" required>
        </div>
        <div class="form-group">
            <label for="description">Descrição <span style="color: var(--text-muted); font-weight: 400;">(opcional)</span></label>
            <textarea id="description" name="description" placeholder="Sobre o que é este episódio?"></textarea>
        </div>
        <div class="form-group">
            <label for="category">Categoria <span style="color: var(--text-muted); font-weight: 400;">(opcional)</span></label>
            <select id="category" name="category">
                <option value="">Selecionar...</option>
                <option>Tecnologia</option>
                <option>Negócios</option>
                <option>Educação</option>
                <option>Entretenimento</option>
                <option>Saúde</option>
                <option>Outros</option>
            </select>
        </div>
        <div class="form-group">
            <label>Arquivo de áudio</label>
            <label class="file-input-label">
                <input type="file" name="audio" accept="audio/*" required id="audio-input">
                <span id="file-name">🎵 Clique para selecionar o arquivo</span>
            </label>
        </div>
        <button type="submit" class="form-submit">Publicar episódio</button>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('audio-input');
    const fileName = document.getElementById('file-name');

    input.addEventListener('change', function () {
        if (this.files.length > 0) {
            fileName.textContent = '✅ ' + this.files[0].name;
        }
    });
});
</script>