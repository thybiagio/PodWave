<div class="episode-container">

    <div class="episode-hero">
        <div class="episode-cover">

    <% if (podcast.coverPath && podcast.coverPath !== 'default-cover.png') { %>

        <img
            src="/uploads/covers/<%= podcast.coverPath %>"
            alt="<%= podcast.title %>">

    <% } else { %>

        <div class="default-cover">
            🎙️
        </div>

    <% } %>

</div>

        <div class="episode-info">
            <span class="badge">
                <%= podcast.category || 'Podcast' %>
            </span>

            <h1><%= podcast.title %></h1>

            <% if (podcast.description) { %>
                <p class="episode-description">
                    <%= podcast.description %>
                </p>
            <% } %>
        </div>
    </div>

    <% if (user && user.id === podcast.userId) { %>
        <div class="actions">
            <a href="/podcasts/<%= podcast.id %>/upload" class="btn-back">
                + Novo episódio
            </a>

            <a href="/podcasts/<%= podcast.id %>/edit" class="btn-back">
                ✎ Editar
            </a>

            <form action="/podcasts/<%= podcast.id %>/delete" method="POST" style="display:inline;">
                <button type="submit" class="btn-back" onclick="return confirm('Tem certeza que deseja deletar este podcast?');">
                    🗑 Deletar
                </button>
            </form>
        </div>
    <% } %>

    <div class="feed-header" style="margin-top: 2rem;">
        <h2>Episódios</h2>
    </div>

    <% if (typeof episodes !== 'undefined' && episodes.length > 0) { %>
        <div class="episodes-grid">
            <% episodes.forEach(ep => { %>
                <a href="/episodes/<%= ep.id %>" style="text-decoration: none; color: inherit;">
                    <div class="episode-card">
                        <div class="episode-card-cover">

    <% if (ep.coverPath && ep.coverPath !== 'default-cover.png') { %>

        <img
            src="/uploads/covers/<%= ep.coverPath %>"
            alt="<%= ep.title %>">

    <% } else { %>

        <div class="default-cover">
            🎙
        </div>

    <% } %>

</div>
                        <div class="episode-card-body">
                            <h3><%= ep.title %></h3>
                            <p class="meta"><%= ep.plays || 0 %> reproduções</p>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-state">
            <div class="icon">🎙</div>
            <p>Nenhum episódio publicado ainda.</p>
        </div>
    <% } %>

    <div class="actions">
        <a href="/podcasts" class="btn-back">
            ← Voltar
        </a>
    </div>

</div>