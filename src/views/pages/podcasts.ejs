<div class="feed-header">
    <h1>Podcasts</h1>
   <a href="/podcasts/new" class="publish-pill">
    <span>+</span>
    Novo podcast
</a>
</div>

<div class="feed-filters">
    <a href="/podcasts" class="filter-btn <%= !category ? 'active' : '' %>">Todos</a>
    <a href="/podcasts?category=Tecnologia" class="filter-btn <%= category === 'Tecnologia' ? 'active' : '' %>">Tecnologia</a>
    <a href="/podcasts?category=Negócios" class="filter-btn <%= category === 'Negócios' ? 'active' : '' %>">Negócios</a>
    <a href="/podcasts?category=Educação" class="filter-btn <%= category === 'Educação' ? 'active' : '' %>">Educação</a>
    <a href="/podcasts?category=Entretenimento" class="filter-btn <%= category === 'Entretenimento' ? 'active' : '' %>">Entretenimento</a>
    <a href="/podcasts?category=Saúde" class="filter-btn <%= category === 'Saúde' ? 'active' : '' %>">Saúde</a>
    <a href="/podcasts?category=Outros" class="filter-btn <%= category === 'Outros' ? 'active' : '' %>">Outros</a>
</div>

<% if (typeof podcasts !== 'undefined' && podcasts.length > 0) { %>
    <div class="episodes-grid">
        <% podcasts.forEach(pc => { %>
            <a href="/podcasts/<%= pc.id %>" style="text-decoration: none; color: inherit;">
                <div class="episode-card">
                    <div class="episode-card-cover">

    <% if (pc.coverPath && pc.coverPath !== 'default-cover.png') { %>

        <img
            src="/uploads/covers/<%= pc.coverPath %>"
            alt="<%= pc.title %>">

    <% } else { %>

        <div class="default-cover">
            🎙
        </div>

    <% } %>

</div>
                    <div class="episode-card-body">
                        <h3><%= pc.title %></h3>
                        <% if (pc.category) { %>
                            <span class="badge"><%= pc.category %></span>
                        <% } %>
                    </div>
                </div>
            </a>
        <% }) %>
    </div>
<% } else { %>
    <div class="empty-state">
        <div class="icon">🎙</div>
        <p>Nenhum podcast encontrado.</p>
        <a href="/podcasts/new" class="btn btn-primary">Criar o primeiro</a>
    </div>
<% } %>