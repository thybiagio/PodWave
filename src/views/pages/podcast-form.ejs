<div class="upload-card">
    <h1><%= typeof podcast !== 'undefined' ? 'Editar podcast' : 'Novo podcast' %></h1>
    <p class="subtitle">Preencha os dados do seu podcast.</p>

    <form
        action="<%= typeof podcast !== 'undefined' ? '/podcasts/' + podcast.id + '/edit' : '/podcasts' %>"
        method="POST"
        enctype="multipart/form-data">

        <div class="form-group">
            <label for="title">Título</label>
            <input
                type="text"
                id="title"
                name="title"
                placeholder="Nome do podcast"
                value="<%= typeof podcast !== 'undefined' ? podcast.title : '' %>"
                required>
        </div>

        <div class="form-group">
            <label for="description">
                Descrição
                <span style="color: var(--text-muted); font-weight: 400;">
                    (opcional)
                </span>
            </label>

            <textarea
                id="description"
                name="description"
                placeholder="Sobre o que é este podcast?"><%= typeof podcast !== 'undefined' ? podcast.description : '' %></textarea>
        </div>

        <div class="form-group">
            <label for="category">
                Categoria
                <span style="color: var(--text-muted); font-weight: 400;">
                    (opcional)
                </span>
            </label>

            <select id="category" name="category">
                <option value="">Selecionar...</option>
                <option <%= typeof podcast !== 'undefined' && podcast.category === 'Tecnologia' ? 'selected' : '' %>>Tecnologia</option>
                <option <%= typeof podcast !== 'undefined' && podcast.category === 'Negócios' ? 'selected' : '' %>>Negócios</option>
                <option <%= typeof podcast !== 'undefined' && podcast.category === 'Educação' ? 'selected' : '' %>>Educação</option>
                <option <%= typeof podcast !== 'undefined' && podcast.category === 'Entretenimento' ? 'selected' : '' %>>Entretenimento</option>
                <option <%= typeof podcast !== 'undefined' && podcast.category === 'Saúde' ? 'selected' : '' %>>Saúde</option>
                <option <%= typeof podcast !== 'undefined' && podcast.category === 'Outros' ? 'selected' : '' %>>Outros</option>
            </select>
        </div>

        <!-- CAPA -->

        <div class="form-group">
            <label>Capa do podcast</label>

            <label class="file-input-label">
                <input
                    type="file"
                    name="cover"
                    id="cover-input"
                    accept="image/*">

                <span id="cover-name">
                    🖼️ Clique para selecionar uma capa
                </span>
            </label>

            <div class="cover-preview-wrapper">
                <img
                    id="cover-preview"
                    class="cover-preview"
                    style="display:none;"
                    alt="Prévia da capa">
            </div>
        </div>

        <button type="submit" class="form-submit">
            <%= typeof podcast !== 'undefined' ? 'Salvar alterações' : 'Criar podcast' %>
        </button>

    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

    const coverInput =
        document.getElementById('cover-input');

    const coverName =
        document.getElementById('cover-name');

    const preview =
        document.getElementById('cover-preview');

    if (coverInput) {

        coverInput.addEventListener('change', function () {

            if (this.files.length > 0) {

                const file = this.files[0];

                coverName.textContent =
                    '🖼️ ' + file.name;

                preview.src =
                    URL.createObjectURL(file);

                preview.style.display =
                    'block';
            }

        });

    }

});
</script>